<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Educational Attainment"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <!-- Checkboxes for Required Educational Attainment -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <CheckBox
                android:id="@+id/chkElementary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Elementary"
                android:layout_weight="1"/>

            <CheckBox
                android:id="@+id/chkSecondary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Secondary"
                android:layout_weight="1"/>

            <CheckBox
                android:id="@+id/chkCollege"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="College"
                android:layout_weight="1"/>

            <CheckBox
                android:id="@+id/chkGraduate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Graduate"
                android:layout_weight="1"/>
        </LinearLayout>

        <!-- Education Details Table -->
        <TableLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:stretchColumns="1">

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Level"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Name of School"
                    android:textAlignment="center"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Degree/Course"
                    android:textAlignment="center"
                    android:textStyle="bold" />
            </TableRow>

            <!-- Elementary -->
            <TableRow>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Elementary"/>

                <EditText
                    android:id="@+id/elementarySchool"
                    android:layout_width="295dp"
                    android:layout_height="wrap_content"
                    android:enabled="false"
                    android:hint="Name of School" />

                <EditText
                    android:id="@+id/elementaryDegree"
                    android:layout_width="287dp"
                    android:layout_height="wrap_content"
                    android:enabled="false"
                    android:hint="Basic Education" />
            </TableRow>

            <!-- Secondary -->
            <TableRow>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Secondary"/>

                <EditText
                    android:id="@+id/secondarySchool"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:hint="Name of School"
                    android:enabled="false"/>

                <EditText
                    android:id="@+id/secondaryDegree"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:hint="Basic Education"
                    android:enabled="false"/>
            </TableRow>

            <!-- Vocational (optional, no checkbox) -->
            <TableRow>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vocational"/>

                <EditText
                    android:id="@+id/vocationalSchool"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:hint="Name of School (Optional)"/>

                <EditText
                    android:id="@+id/vocationalDegree"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:hint="Degree/Course (Optional)"/>
            </TableRow>

            <!-- College -->
            <TableRow>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="College"/>

                <EditText
                    android:id="@+id/collegeSchool"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:hint="Name of School"
                    android:enabled="false"/>

                <EditText
                    android:id="@+id/collegeDegree"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:hint="Degree/Course"
                    android:enabled="false"/>
            </TableRow>

            <!-- Graduate Studies -->
            <TableRow>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Graduate Studies"/>

                <EditText
                    android:id="@+id/graduateSchool"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:hint="Name of School"
                    android:enabled="false"/>

                <EditText
                    android:id="@+id/graduateDegree"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:hint="Degree/Course"
                    android:enabled="false"/>
            </TableRow>
        </TableLayout>

        <!-- Next Button -->
        <Button
            android:id="@+id/btnNext"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:text="Next"
            android:backgroundTint="#2196F3"
            android:textColor="@android:color/white"/>
    </LinearLayout>
</ScrollView>